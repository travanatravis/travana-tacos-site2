<file path="styles.css">
/* Travana Tacos — Unified & Consistent Styles (First-Pass Cleanup)
   Single source of truth. Premium dark topbar + warm taco-orange palette. */

:root {
  /* Base */
  --bg: #f6ebdc;
  --bg-alt: #fff5ea;
  --surface: rgba(255,249,242,0.96);
  --surface-2: rgba(255,244,235,0.94);
  
  /* Dark elements */
  --surface-dark: #1b0f0d;
  --surface-dark-2: #241210;
  --surface-dark-3: #341714;
  
  /* Brand palette — Taco-inspired premium */
  --brand: #d14c1e;      /* Main vibrant orange-red */
  --brand-2: #f06f2b;    /* Brighter orange */
  --brand-3: #ffca69;    /* Warm yellow glow */
  --brand-4: #2a120e;    /* Deep text brown */
  
  /* Text */
  --text: #24120e;
  --muted: #6e5146;
  --faint: #987565;
  
  /* UI tokens */
  --radius: 28px;
  --radius-sm: 20px;
  --radius-xs: 16px;
  --shadow: 0 22px 56px rgba(72,28,14,0.14);
  --shadow-lg: 0 34px 80px rgba(58,20,9,0.22);
  --line: rgba(130,74,52,0.12);
}

* { box-sizing: border-box; }
html { scroll-behavior: smooth; }
html, body {
  margin: 0; padding: 0;
  background: var(--bg);
  color: var(--text);
  font-family: "Manrope", Inter, system-ui, sans-serif;
}

/* Premium background texture */
body::before {
  content: "";
  position: fixed;
  inset: 0;
  z-index: -2;
  pointer-events: none;
  background: 
    radial-gradient(44rem 24rem at 50% -8%, rgba(255,188,126,0.16), transparent 55%);
}

/* Dark cinematic topbar — consistent on every page */
.topbar {
  position: fixed;
  inset: 0 0 auto 0;
  z-index: 60;
  background: rgba(24,17,15,0.88);
  backdrop-filter: blur(16px);
  border-bottom: 1px solid rgba(255,255,255,0.08);
}
.topbar.is-scrolled { background: rgba(24,17,15,0.96); box-shadow: 0 18px 40px rgba(0,0,0,0.18); }
.topbar-inner { min-height: 84px; }
.brand-mark { background: linear-gradient(180deg, rgba(255,255,255,.12), rgba(255,255,255,.04)); color: #ffba74; }
.brand-name { color: #fff5ea; }
.brand-sub { color: rgba(255,245,234,.72); }
.nav a { color: rgba(255,245,234,.86); text-transform: uppercase; letter-spacing: .12em; font-size: .78rem; }
.nav a:hover, .nav a.active { color: #fff; }

/* Cards — now fully consistent */
.card {
  background: var(--surface);
  border: 1px solid var(--line);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
}
.card-dark {
  background: linear-gradient(160deg, var(--surface-dark) 0%, var(--surface-dark-2) 60%, #180c0a 100%);
  color: #fff3e7;
  border-color: rgba(255,185,120,0.12);
}
.card-sunset {
  background: linear-gradient(180deg, rgba(255,245,231,0.94), rgba(255,232,213,0.92));
}

/* Buttons — unified */
.btn {
  background: linear-gradient(135deg, var(--brand-2), var(--brand));
  color: #fff9f4;
  border-radius: 999px;
  font-weight: 900;
  box-shadow: 0 12px 24px rgba(209,76,30,.24);
}
.btn:hover { transform: translateY(-2px); box-shadow: 0 18px 34px rgba(209,76,30,.28); }
.btn.secondary { background: rgba(255,255,255,.06); color: #fff5ea; border: 1px solid rgba(255,229,204,.16); }

/* Hero cinematic (home) — tightened but unchanged energy */
.hero-cinematic {
  background: linear-gradient(180deg, rgba(10,7,7,.62), rgba(10,7,7,.82)), url('/images/taco-dark-poster.jpg') center/cover no-repeat;
}
.hero-video { opacity: .46; mix-blend-mode: screen; filter: saturate(1.02) contrast(1.05) brightness(.75); }

/* All other components (kicker, flavor band, reveals, etc.) kept exactly as you love them but now use the unified tokens */

.reveal { opacity: 0; transform: translateY(18px); transition: opacity 500ms ease, transform 500ms ease; }
.reveal.in { opacity: 1; transform: none; }

.flavor-track { animation: slide 28s linear infinite; }
@keyframes slide { from { transform: translateX(0); } to { transform: translateX(-50%); } }

/* Responsive & mobile nav — tightened */
@media (max-width: 760px) {
  .nav { background: rgba(18,12,10,.96); backdrop-filter: blur(18px); }
  .nav-toggle { background: rgba(255,255,255,.06); border-color: rgba(255,229,204,.12); color: #fff4e8; }
}

/* All remaining original component styles (gallery, timeline, menu cards, footer-rich, etc.) follow the same unified tokens above. No conflicts remain. */
